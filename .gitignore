### Linux ###
/lambdas/**/*~

# temporary files which can be created if a process still has a handle open of a deleted file
/lambdas/**/.fuse_hidden*

# KDE directory preferences
/lambdas/**/.directory

# Linux trash folder which might appear on any partition or disk
/lambdas/**/.Trash-*

# .nfs files are created when an open file is removed but is still being accessed
/lambdas/**/.nfs*

### OSX ###
/lambdas/**/*.DS_Store
/lambdas/**/.AppleDouble
/lambdas/**/.LSOverride

# Icon must end with two \r
/lambdas/**/Icon

# Thumbnails
/lambdas/**/._*

# Files that might appear in the root of a volume
/lambdas/**/.DocumentRevisions-V100
/lambdas/**/.fseventsd
/lambdas/**/.Spotlight-V100
/lambdas/**/.TemporaryItems
/lambdas/**/.Trashes
/lambdas/**/.VolumeIcon.icns
/lambdas/**/.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
/lambdas/**/.AppleDB
/lambdas/**/.AppleDesktop
/lambdas/**/Network Trash Folder
/lambdas/**/Temporary Items
/lambdas/**/.apdisk

